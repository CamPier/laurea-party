# Configurazione Firebase (Project Settings -> General -> Your apps -> SDK config)
# Copia questo file in `.env` e inserisci i tuoi valori.
# Le variabili VITE_* sono incluse nel bundle pubblico: sono valori "pubblici"
# del progetto Firebase, protetti dalle Firestore Security Rules, non segreti.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
